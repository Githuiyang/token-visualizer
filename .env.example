# Token Visualizer - Environment Variables for Vercel Deployment

# ===================================================================
# REQUIRED FOR VERCEL DEPLOYMENT
# ===================================================================

# Turso Database URL (LibSQL)
# Get your free database at: https://turso.tech
# Format: libsql://your-database-name.turso.io
TURSO_DATABASE_URL=libsql://your-database.turso.io

# Turso Auth Token
# Create at: https://turso.tech/dashboard > Your Database > Settings > Authentication
TURSO_AUTH_TOKEN=your-turso-auth-token

# ===================================================================
# OPTIONAL
# ===================================================================

# Port (for local development only)
PORT=3000
