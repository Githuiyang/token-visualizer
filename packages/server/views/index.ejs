<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Token Visualizer</title>
  <link rel="stylesheet" href="/css/index.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📊</text></svg>">
</head>
<body>
  <div class="container">
    <header class="hero">
      <div class="logo">
        <h1>Token Visualizer</h1>
      </div>
      <p class="tagline">Track your AI token usage and costs</p>
      <p class="sign-in-prompt" id="sign-in-prompt">Already have an account? <button class="sign-in-btn" id="sign-in-btn">Sign in</button></p>
      <p class="user-welcome" id="user-welcome" style="display: none;">
        Welcome back! <a href="/dashboard" class="btn-link">Dashboard</a> <a href="/leaderboard" class="btn-link">Leaderboard</a>
        <button class="sign-out-btn" id="sign-out-btn">Sign out</button>
      </p>
    </header>

    <main>
      <!-- Registration Form (shown when not logged in) -->
      <section class="register-section" id="register-form">
        <h2>Get Started</h2>
        <p class="subtitle">Enter your details to generate your API key</p>

        <form id="registration-form">
          <div class="form-group">
            <label for="email">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="you@example.com"
              required
              autocomplete="email"
            >
            <span class="help-text">Your API key will be generated from your email</span>
          </div>

          <div class="form-group">
            <label for="nickname">Nickname</label>
            <input
              type="text"
              id="nickname"
              name="nickname"
              placeholder="Your display name"
              required
              maxlength="30"
              autocomplete="nickname"
            >
            <span class="help-text">Shown on leaderboards (max 30 characters)</span>
          </div>

          <div class="form-group checkbox-group">
            <label class="checkbox-label">
              <input type="checkbox" id="show-on-leaderboard" name="show_on_leaderboard">
              <span>Appear on public leaderboard</span>
            </label>
          </div>

          <button type="submit" class="btn btn-primary" id="submit-btn">
            <span class="btn-text">Generate API Key</span>
            <span class="spinner"></span>
          </button>

          <div class="error-message" id="error-message"></div>
        </form>
      </section>

      <!-- Logged In Section (shown when logged in) -->
      <section class="logged-in-section" id="logged-in-section" style="display: none;">
        <h2>Your API Key</h2>
        <p class="subtitle">Save this key - you'll need it to upload your data</p>

        <div class="key-container">
          <code id="user-api-key"></code>
          <button class="btn-copy" id="copy-api-key-btn">Copy</button>
        </div>

        <h2 style="margin-top: 3rem;">Get Started</h2>
        <p class="subtitle">Follow these steps to upload your data</p>

        <div class="todo-list">
          <div class="todo-item">
            <div class="todo-number">1</div>
            <div class="todo-content">
              <h3>Install CLI</h3>
              <p>Run this command in your terminal</p>
              <div class="command-box">
                <code>npm install -g token-viz-cli</code>
                <button class="btn-copy" data-copy="npm install -g token-viz-cli">Copy</button>
              </div>
            </div>
          </div>

          <div class="todo-item">
            <div class="todo-number">2</div>
            <div class="todo-content">
              <h3>Upload your data</h3>
              <p>Push your AI usage data to the server</p>
              <div class="command-box">
                <code id="upload-command">Loading...</code>
                <button class="btn-copy" id="copy-upload-btn">Copy</button>
              </div>
            </div>
          </div>

          <div class="todo-item">
            <div class="todo-number">3</div>
            <div class="todo-content">
              <h3>View your dashboard</h3>
              <p>See your usage statistics and trends</p>
              <div class="upload-actions">
                <a href="/dashboard" class="btn btn-secondary">Open Dashboard</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Features Section -->
      <section class="features-section">
        <h2>Features</h2>
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon">📊</div>
            <h3>Visualize</h3>
            <p>Track your token consumption over time with clean charts and heatmaps</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">💰</div>
            <h3>Costs</h3>
            <p>Monitor spending across different AI models and projects</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">👥</div>
            <h3>Groups</h3>
            <p>Create groups to compare usage with friends and teammates</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">🏆</div>
            <h3>Leaderboard</h3>
            <p>Optional public leaderboard to see how you rank among developers</p>
          </div>
        </div>
      </section>

      <!-- CLI Reference (Collapsible) - Hidden when logged in -->
      <section class="reference-section" id="reference-section">
        <button class="reference-toggle" id="reference-toggle">
          <span>CLI Commands Reference</span>
          <span class="toggle-icon">▼</span>
        </button>
        <div class="reference-content" id="reference-content">
          <div class="commands-table">
            <div class="command-row">
              <code data-replace-key-template="push">token-viz push --key YOUR_API_KEY</code>
              <span>Upload data</span>
            </div>
            <div class="command-row">
              <code data-replace-key-template="dash">token-viz dash --key YOUR_API_KEY</code>
              <span>Open dashboard</span>
            </div>
            <div class="command-row">
              <code data-replace-key-template="config">token-viz config --set-key YOUR_API_KEY</code>
              <span>Save API key</span>
            </div>
            <div class="command-row">
              <code>token-viz stats</code>
              <span>Show local stats</span>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <p>Token Visualizer — Track your AI usage</p>
    </footer>
  </div>

  <!-- Language Toggle Button -->
  <button id="lang-toggle" class="lang-toggle">EN</button>

  <style>
    .lang-toggle {
      position: fixed;
      top: 20px;
      right: 20px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.2);
      color: #e8e8e8;
      padding: 8px 16px;
      border-radius: 20px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 500;
      transition: all 0.2s;
      z-index: 100;
    }
    .lang-toggle:hover {
      background: rgba(255, 255, 255, 0.15);
      border-color: rgba(255, 255, 255, 0.3);
    }
  </style>

  <script>
    // Translations
    const i18n = {
      en: {
        tagline: 'Track your AI token usage and costs',
        signInPrompt: 'Already have an account? ',
        signInBtn: 'Sign in',
        welcomeBack: 'Welcome back! ',
        dashboard: 'Dashboard',
        leaderboard: 'Leaderboard',
        signOut: 'Sign out',
        getStarted: 'Get Started',
        generateKey: 'Your API key will be generated from your email',
        nickname: 'Your display name',
        nicknameHelp: 'Shown on leaderboards (max 30 characters)',
        appearOnLeaderboard: 'Appear on public leaderboard',
        generateApiKey: 'Generate API Key',
        yourApiKey: 'Your API Key',
        saveKey: 'Save this key - you\\'ll need it to upload your data',
        installCLI: 'Install CLI',
        installCmd: 'Run this command in your terminal',
        uploadData: 'Upload your data',
        uploadDesc: 'Push your AI usage data to the server',
        viewDashboard: 'View your dashboard',
        viewDashboardDesc: 'See your usage statistics and trends',
        openDashboard: 'Open Dashboard',
        features: 'Features',
        visualize: 'Visualize',
        visualizeDesc: 'Track your token consumption over time with clean charts and heatmaps',
        costs: 'Costs',
        costsDesc: 'Monitor spending across different AI models and projects',
        groups: 'Groups',
        groupsDesc: 'Create groups to compare usage with friends and teammates',
        leaderboard: 'Leaderboard',
        leaderboardDesc: 'Optional public leaderboard to see how you rank among developers',
        cliReference: 'CLI Commands Reference',
        upload: 'Upload data',
        openDash: 'Open dashboard',
        saveKey: 'Save API key',
        showStats: 'Show local stats',
        enterKey: 'Enter your API key'
      },
      zh: {
        tagline: '追踪你的 AI token 使用和成本',
        signInPrompt: '已有账号？',
        signInBtn: '登录',
        welcomeBack: '欢迎回来！',
        dashboard: '仪表盘',
        leaderboard: '排行榜',
        signOut: '退出',
        getStarted: '开始使用',
        generateKey: '你的 API key 将根据邮箱生成',
        nickname: '显示名称',
        nicknameHelp: '在排行榜上显示（最多 30 个字符）',
        appearOnLeaderboard: '在公开排行榜显示',
        generateApiKey: '生成 API Key',
        yourApiKey: '你的 API Key',
        saveKey: '保存此密钥 - 上传数据时需要',
        installCLI: '安装 CLI',
        installCmd: '在终端中运行此命令',
        uploadData: '上传数据',
        uploadDesc: '将你的 AI 使用数据推送到服务器',
        viewDashboard: '查看仪表盘',
        viewDashboardDesc: '查看使用统计和趋势',
        openDashboard: '打开仪表盘',
        features: '功能特性',
        visualize: '可视化',
        visualizeDesc: '通过清晰的图表和热力图追踪 token 消耗',
        costs: '成本',
        costsDesc: '监控不同 AI 模型和项目的花费',
        groups: '群组',
        groupsDesc: '创建群组，与朋友和团队成员比较使用情况',
        leaderboard: '排行榜',
        leaderboardDesc: '可选的公开排行榜，查看你在开发者中的排名',
        cliReference: 'CLI 命令参考',
        upload: '上传数据',
        openDash: '打开仪表盘',
        saveKey: '保存 API Key',
        showStats: '显示本地统计',
        enterKey: '输入你的 API Key'
      }
    };

    let currentLang = localStorage.getItem('tokenviz_lang') || 'en';

    function updateLanguage() {
      const t = i18n[currentLang];
      const langBtn = document.getElementById('lang-toggle');
      if (langBtn) langBtn.textContent = currentLang === 'en' ? 'EN' : '中';

      // Hero section
      const tagline = document.querySelector('.tagline');
      if (tagline) tagline.textContent = t.tagline;

      const signInPrompt = document.getElementById('sign-in-prompt');
      if (signInPrompt) {
        signInPrompt.innerHTML = `${t.signInPrompt}<button class="sign-in-btn" id="sign-in-btn">${t.signInBtn}</button>`;
        // Re-attach event listener
        document.getElementById('sign-in-btn').addEventListener('click', () => {
          document.getElementById('signin-modal').style.display = 'flex';
        });
      }

      const userWelcome = document.getElementById('user-welcome');
      if (userWelcome) {
        const links = userWelcome.querySelectorAll('a');
        if (links[0]) links[0].textContent = t.dashboard;
        if (links[1]) links[1].textContent = t.leaderboard;
        const signOutBtn = document.getElementById('sign-out-btn');
        if (signOutBtn) signOutBtn.textContent = t.signOut;
      }

      // Register section
      const getStarted = document.querySelector('#register-form h2');
      if (getStarted) getStarted.textContent = t.generateApiKey;

      const subtitle = document.querySelector('#register-form .subtitle');
      if (subtitle) subtitle.textContent = t.generateKey;

      const nicknameLabel = document.querySelector('label[for="nickname"]');
      if (nicknameLabel) nicknameLabel.textContent = t.nickname;

      const nicknamePlaceholder = document.querySelector('input#nickname');
      if (nicknamePlaceholder) nicknamePlaceholder.placeholder = t.nickname;

      const nicknameHelp = document.querySelector('input#nickname'] + '+ span';
      if (document.querySelector('input#nickname']')) {
        const helpText = document.querySelector('#register-form .help-text');
        if (helpText) helpText.textContent = t.nicknameHelp;
      }

      const checkboxLabel = document.querySelector('.checkbox-label span');
      if (checkboxLabel) checkboxLabel.textContent = t.appearOnLeaderboard;

      const submitBtn = document.querySelector('#submit-btn .btn-text');
      if (submitBtn) submitBtn.textContent = t.generateApiKey;

      // Logged in section
      const loggedInSection = document.getElementById('logged-in-section');
      if (loggedInSection) {
        loggedInSection.querySelector('h2').textContent = t.yourApiKey;
        loggedInSection.querySelectorAll('h2')[1].textContent = t.getStarted;
        loggedInSection.querySelector('.subtitle').textContent = t.saveKey;
      }

      const copyBtn = document.getElementById('copy-api-key-btn');
      if (copyBtn) copyBtn.textContent = 'Copy';

      // Todo list
      const todoItems = document.querySelectorAll('.todo-content h3');
      if (todoItems[0]) todoItems[0].textContent = t.installCLI;
      const todoP = document.querySelectorAll('.todo-content p');
      if (todoP[0]) todoP[0].textContent = t.installCmd;
      if (todoP[1]) todoP[1].textContent = t.uploadDesc;
      if (todoP[2]) todoP[2].textContent = t.viewDashboardDesc;

      const dashboardBtn = document.querySelector('.upload-actions .btn-secondary');
      if (dashboardBtn) dashboardBtn.textContent = t.openDashboard;

      // Features
      const featuresSection = document.querySelector('.features-section h2');
      if (featuresSection) featuresSection.textContent = t.features;

      const features = document.querySelectorAll('.feature-card h3');
      const featureDescs = document.querySelectorAll('.feature-card p');
      if (features[0]) features[0].textContent = t.visualize;
      if (features[1]) features[1].textContent = t.costs;
      if (features[2]) features[2].textContent = t.groups;
      if (features[3]) features[3].textContent = t.leaderboard;
      if (featureDescs[0]) featureDescs[0].textContent = t.visualizeDesc;
      if (featureDescs[1]) featureDescs[1].textContent = t.costsDesc;
      if (featureDescs[2]) featureDescs[2].textContent = t.groupsDesc;
      if (featureDescs[3]) featureDescs[3].textContent = t.leaderboardDesc;

      // Reference section
      const refToggle = document.getElementById('reference-toggle');
      if (refToggle) {
        refToggle.querySelector('span:first-child').textContent = t.cliReference;
      }

      const refTable = document.querySelector('.commands-table');
      if (refTable) {
        const spans = refTable.querySelectorAll('.command-row span');
        if (spans[0]) spans[0].textContent = t.upload;
        if (spans[1]) spans[1].textContent = t.openDash;
        if (spans[2]) spans[2].textContent = t.saveKey;
        if (spans[3]) spans[3].textContent = t.showStats;
      }

      // Sign in modal
      const signinModal = document.querySelector('.modal-signin h2');
      if (signinModal) signinModal.textContent = t.signInBtn;

      const signinSubtitle = document.querySelector('.modal-signin .subtitle');
      if (signinSubtitle) signinSubtitle.textContent = t.enterKey;

      const signinSubmit = document.querySelector('#signin-submit .btn-text');
      if (signinSubmit) signinSubmit.textContent = t.signInBtn;

      // Footer
      const footer = document.querySelector('footer p');
      if (footer) footer.textContent = `${t.brand} — ${t.tagline}`;
    }

    function toggleLanguage() {
      currentLang = currentLang === 'en' ? 'zh' : 'en';
      localStorage.setItem('tokenviz_lang', currentLang);
      updateLanguage();
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
      updateLanguage();

      const langBtn = document.getElementById('lang-toggle');
      if (langBtn) {
        langBtn.addEventListener('click', toggleLanguage);
      }
    });
  </script>

  <!-- Sign In Modal -->
  <div class="modal-overlay" id="signin-modal" style="display: none;">
    <div class="modal-signin">
      <button class="modal-close" id="signin-close">×</button>
      <h2>Sign In</h2>
      <p class="subtitle">Enter your API key</p>
      <form id="signin-form">
        <div class="form-group">
          <label for="signin-api-key">API Key</label>
          <input
            type="text"
            id="signin-api-key"
            placeholder="tv_xxxxx..."
            required
          >
        </div>
        <button type="submit" class="btn btn-primary" id="signin-submit">
          <span class="btn-text">Sign In</span>
          <span class="spinner"></span>
        </button>
        <div class="error-message" id="signin-error"></div>
      </form>
    </div>
  </div>

  <script src="/js/register.js"></script>
  <script>
    // Reference toggle - only if element exists
    const refToggle = document.getElementById('reference-toggle');
    if (refToggle) {
      refToggle.addEventListener('click', () => {
        const content = document.getElementById('reference-content');
        const icon = document.querySelector('.toggle-icon');
        content.classList.toggle('show');
        icon.textContent = content.classList.contains('show') ? '▲' : '▼';
      });
    }
  </script>
</body>
</html>
