<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Token Visualizer</title>
  <link rel="stylesheet" href="/css/index.css">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📊</text></svg>">
</head>
<body>
  <div class="container">
    <header class="hero">
      <div class="logo">
        <h1>Token Visualizer</h1>
      </div>
      <p class="tagline">Track your AI token usage and costs</p>
      <p class="sign-in-prompt" id="sign-in-prompt">Already have an account? <button class="sign-in-btn" id="sign-in-btn">Sign in</button></p>
      <p class="user-welcome" id="user-welcome" style="display: none;">
        Welcome back! <a href="/dashboard" class="btn-link">Dashboard</a> <a href="/leaderboard" class="btn-link">Leaderboard</a>
        <button class="sign-out-btn" id="sign-out-btn">Sign out</button>
      </p>
    </header>

    <main>
      <!-- Registration Form (shown when not logged in) -->
      <section class="register-section" id="register-form">
        <h2>Get Started</h2>
        <p class="subtitle">Enter your details to generate your API key</p>

        <form id="registration-form">
          <div class="form-group">
            <label for="email">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="you@example.com"
              required
              autocomplete="email"
            >
            <span class="help-text">Your API key will be generated from your email</span>
          </div>

          <div class="form-group">
            <label for="nickname">Nickname</label>
            <input
              type="text"
              id="nickname"
              name="nickname"
              placeholder="Your display name"
              required
              maxlength="30"
              autocomplete="nickname"
            >
            <span class="help-text">Shown on leaderboards (max 30 characters)</span>
          </div>

          <div class="form-group checkbox-group">
            <label class="checkbox-label">
              <input type="checkbox" id="show-on-leaderboard" name="show_on_leaderboard">
              <span>Appear on public leaderboard</span>
            </label>
          </div>

          <button type="submit" class="btn btn-primary" id="submit-btn">
            <span class="btn-text">Generate API Key</span>
            <span class="spinner"></span>
          </button>

          <div class="error-message" id="error-message"></div>
        </form>
      </section>

      <!-- Logged In Section (shown when logged in) -->
      <section class="logged-in-section" id="logged-in-section" style="display: none;">
        <h2>Your API Key</h2>
        <p class="subtitle">Save this key - you'll need it to upload your data</p>

        <div class="key-container">
          <code id="user-api-key"></code>
          <button class="btn-copy" id="copy-api-key-btn">Copy</button>
        </div>

        <h2 style="margin-top: 3rem;">Get Started</h2>
        <p class="subtitle">Follow these steps to upload your data</p>

        <div class="todo-list">
          <div class="todo-item">
            <div class="todo-number">1</div>
            <div class="todo-content">
              <h3>Install CLI</h3>
              <p>Run this command in your terminal</p>
              <div class="command-box">
                <code>npm install -g token-viz-cli</code>
                <button class="btn-copy" data-copy="npm install -g token-viz-cli">Copy</button>
              </div>
            </div>
          </div>

          <div class="todo-item">
            <div class="todo-number">2</div>
            <div class="todo-content">
              <h3>Upload your data</h3>
              <p>Push your AI usage data to the server</p>
              <div class="command-box">
                <code id="upload-command">Loading...</code>
                <button class="btn-copy" id="copy-upload-btn">Copy</button>
              </div>
            </div>
          </div>

          <div class="todo-item">
            <div class="todo-number">3</div>
            <div class="todo-content">
              <h3>View your dashboard</h3>
              <p>See your usage statistics and trends</p>
              <div class="upload-actions">
                <a href="/dashboard" class="btn btn-secondary">Open Dashboard</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Features Section -->
      <section class="features-section">
        <h2>Features</h2>
        <div class="features-grid">
          <div class="feature-card">
            <div class="feature-icon">📊</div>
            <h3>Visualize</h3>
            <p>Track your token consumption over time with clean charts and heatmaps</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">💰</div>
            <h3>Costs</h3>
            <p>Monitor spending across different AI models and projects</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">👥</div>
            <h3>Groups</h3>
            <p>Create groups to compare usage with friends and teammates</p>
          </div>
          <div class="feature-card">
            <div class="feature-icon">🏆</div>
            <h3>Leaderboard</h3>
            <p>Optional public leaderboard to see how you rank among developers</p>
          </div>
        </div>
      </section>

      <!-- CLI Reference (Collapsible) - Hidden when logged in -->
      <section class="reference-section" id="reference-section">
        <button class="reference-toggle" id="reference-toggle">
          <span>CLI Commands Reference</span>
          <span class="toggle-icon">▼</span>
        </button>
        <div class="reference-content" id="reference-content">
          <div class="commands-table">
            <div class="command-row">
              <code data-replace-key-template="push">token-viz push --key YOUR_API_KEY</code>
              <span>Upload data</span>
            </div>
            <div class="command-row">
              <code data-replace-key-template="dash">token-viz dash --key YOUR_API_KEY</code>
              <span>Open dashboard</span>
            </div>
            <div class="command-row">
              <code data-replace-key-template="config">token-viz config --set-key YOUR_API_KEY</code>
              <span>Save API key</span>
            </div>
            <div class="command-row">
              <code>token-viz stats</code>
              <span>Show local stats</span>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer>
      <p>Token Visualizer — Track your AI usage</p>
    </footer>
  </div>

  <!-- Sign In Modal -->
  <div class="modal-overlay" id="signin-modal" style="display: none;">
    <div class="modal-signin">
      <button class="modal-close" id="signin-close">×</button>
      <h2>Sign In</h2>
      <p class="subtitle">Enter your API key</p>
      <form id="signin-form">
        <div class="form-group">
          <label for="signin-api-key">API Key</label>
          <input
            type="text"
            id="signin-api-key"
            placeholder="tv_xxxxx..."
            required
          >
        </div>
        <button type="submit" class="btn btn-primary" id="signin-submit">
          <span class="btn-text">Sign In</span>
          <span class="spinner"></span>
        </button>
        <div class="error-message" id="signin-error"></div>
      </form>
    </div>
  </div>

  <script src="/js/register.js"></script>
  <script>
    // Reference toggle - only if element exists
    const refToggle = document.getElementById('reference-toggle');
    if (refToggle) {
      refToggle.addEventListener('click', () => {
        const content = document.getElementById('reference-content');
        const icon = document.querySelector('.toggle-icon');
        content.classList.toggle('show');
        icon.textContent = content.classList.contains('show') ? '▲' : '▼';
      });
    }
  </script>
</body>
</html>
